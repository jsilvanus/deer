{
  "name": "@jsilvanus/chattydeer",
  "version": "0.4.2",
  "description": "A Node.js minimal LLM chat completionist — wraps embedeer with Explainer and LLM adapter capabilities",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "chattydeer": "dist/cli.js"
  },
  "files": [
    "assets",
    "dist",
    "README.md",
    "explainer-contract.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:types": "tsc -p tsconfig.types.json",
    "prepare": "pnpm run build && pnpm run build:types",
    "prepublishOnly": "pnpm run build && pnpm run build:types",
    "test": "pnpm run build && node --test test/*.test.js",
    "cli": "pnpm run build && node ./dist/cli.js",
    "coverage": "pnpm run build && c8 node --test test/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jsilvanus/chattydeer.git"
  },
  "keywords": [
    "llm",
    "chat",
    "huggingface",
    "transformers",
    "explainer",
    "nlp",
    "onnxruntime"
  ],
  "author": "jsilvanus",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bugs": {
    "url": "https://github.com/jsilvanus/chattydeer/issues"
  },
  "homepage": "https://github.com/jsilvanus/chattydeer#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.0.1",
    "@jsilvanus/embedeer": "1.3.1"
  },
  "devDependencies": {
    "c8": "^8.0.1",
    "typescript": "^5.3.0",
    "@types/node": "^20.8.0"
  }
}
